{
  "name": "bodyshapecoach-bot",
  "version": "1.0.0",
  "description": "Telegram bot for personalized diet and fitness coaching",
  "main": "src/worker.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute bodyshapecoach-db --file=./src/database/schema.sql",
    "db:backup": "wrangler d1 backup create bodyshapecoach-db",
    "db:export": "wrangler d1 export bodyshapecoach-db",
    "keys:generate": "node scripts/generate-keys.js",
    "test": "jest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "telegraf": "^4.16.3",
    "openai": "^4.28.0",
    "i18next": "^23.7.16",
    "node-cron": "^3.0.3",
    "axios": "^1.6.2",
    "validator": "^13.11.0",
    "uuid": "^9.0.1",
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "country-data": "^0.0.31",
    "moment-timezone": "^0.5.43"
  },
  "devDependencies": {
    "wrangler": "^3.0.0",
    "@cloudflare/workers-types": "^4.20231121.0",
    "jest": "^29.7.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0"
  }
}
